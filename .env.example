# Dandelion runtime config

# API port for the Session Saver HTTP/WebSocket server.
API_PORT=50000

# How long /get-sessions may reuse a cached session list.
SESSIONS_CACHE_TTL_MS=30000

# Terminal log verbosity: debug, info, warn, error, or silent.
DEBUG_LEVEL=info

# Optional Discord webhook that receives every emitted log message.
DISCORD_WEBHOOK_URL=

# Extra solver state logging. Requires DEBUG_LEVEL=debug or info to be visible.
SOLVER_DEBUG=0
